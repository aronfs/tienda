meta {
  name: Sales Analytics by custom date
  type: http
  seq: 3
}

get {
  url: {{base_url}}/api/analytics/sales
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

params:query {
  period: custom
  startDate: 2026-01-01
  endDate: 2026-12-31
  paymentMethod: EFECTIVO
}

script:post-response {
  if (res.status === 200) {
    console.log("Sales analytics consultadas correctamente");
  }
}