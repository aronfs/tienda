meta {
  name: Create Purchase
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/purchases
  body: json
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "providerId": 1,
    "series": "F001",
    "number": "00001",
    "details": [
      {
        "productId": 1,
        "quantity": 50,
        "unitCost": 45.00
      }
    ]
  }
}
