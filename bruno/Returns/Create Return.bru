  token: {{auth_token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "saleId": 1,
    "reason": "Producto defectuoso",
    "details": [
      {
        "productId": 1,
        "quantity": 1
      }
    ]
  }
}
