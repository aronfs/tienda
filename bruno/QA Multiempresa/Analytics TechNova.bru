meta {
  name: Analytics TechNova
  type: http
  seq: 16
}

get {
  url: {{base_url}}/analytics/dashboard
  headers: {
    Authorization: Bearer {{technova_token}}
  }
}

auth: none

script:post-response {
  const data = res.getBody().data;
  console.log("TechNova Analytics Dashboard:");
  console.log("  Products total:", data.products?.total);
  console.log("  Clients active:", data.clients?.active);
  console.log("PASS: Analytics shows only TechNova data");
}
