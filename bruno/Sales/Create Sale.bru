meta {
  name: Create Sale
  type: http
  seq: 3
}

post {
  url: {{base_url}}/api/sales
  body: json
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "clientId": 1,
    "paymentMethod": "EFECTIVO",
    "details": [
      {
        "productId": 1,
        "quantity": 2,
        "discount": 0
      }
    ],
    "discount": 0
  }
}
