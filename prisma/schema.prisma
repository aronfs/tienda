generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CashRegisterStatus {
  ABIERTA
  CERRADA
}

enum MovementType {
  SALE_OUT
  PURCHASE_IN
  ADJUSTMENT
  RETURN_IN
}

enum PaymentMethod {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
  QR
}

enum SaleStatus {
  COMPLETADA
  ANULADA
}

enum PurchaseStatus {
  COMPLETADA
  ANULADA
}

enum BranchStatus {
  OPERATIVE
  MAINTENANCE
  INACTIVE
}

enum InvoiceResolutionStatus {
  ACTIVE
  EXPIRED
  INACTIVE
  EXHAUSTED
}

enum TaxAppliesTo {
  SALE
  PURCHASE
  BOTH
}

model Role {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  description     String?
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  users           User[]
  rolePermissions RolePermission[]
}

model Permission {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  description     String?
  createdAt       DateTime          @default(now())
  rolePermissions RolePermission[]
}

model RolePermission {
  roleId       Int
  permissionId Int
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Company {
  id              Int      @id @default(autoincrement())
  legalName       String
  commercialName  String
  taxId           String   @unique
  email           String
  phone           String?
  website         String?
  logoUrl         String?
  mainAddress     String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  branches        Branch[]
  regionalConfig  RegionalConfig?
  taxes           Tax[]
  invoiceResolutions InvoiceResolution[]
  billingConfig   BillingConfig?
  users           User[]
  products        Product[]
  sales           Sale[]
  purchases       Purchase[]
  inventoryMovements InventoryMovement[]
  cashRegisters   CashRegister[]

  @@map("companies")
}

model Branch {
  id        Int          @id @default(autoincrement())
  companyId Int
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code      String
  name      String
  address   String?
  city      String?
  country   String?
  phone     String?
  email     String?
  managerName String?
  status    BranchStatus @default(OPERATIVE)
  isMain    Boolean      @default(false)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  users     User[]
  sales     Sale[]
  purchases Purchase[]
  cashRegisters CashRegister[]
  inventoryMovements InventoryMovement[]
  invoiceResolutions InvoiceResolution[]

  @@unique([companyId, code])
  @@map("branches")
}

model RegionalConfig {
  id               Int      @id @default(autoincrement())
  companyId        Int      @unique
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  baseCurrency     String   @default("USD")
  timezone         String   @default("America/Guayaquil")
  dateFormat       String   @default("DD/MM/YYYY")
  decimalSeparator String @default(".")
  thousandSeparator String  @default(",")
  language         String   @default("es")
  country          String   @default("Ecuador")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("regional_configs")
}

model Tax {
  id          Int           @id @default(autoincrement())
  companyId   Int
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  description String?
  rate        Float
  isDefault   Boolean       @default(false)
  isActive    Boolean       @default(true)
  appliesTo   TaxAppliesTo  @default(BOTH)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  products    Product[]

  @@map("taxes")
}

model InvoiceResolution {
  id                Int                    @id @default(autoincrement())
  companyId         Int
  company           Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branchId          Int?
  branch            Branch?                @relation(fields: [branchId], references: [id])
  prefix            String
  startNumber       Int
  endNumber         Int
  currentNumber     Int
  authorizationCode String?
  validFrom         DateTime
  validUntil        DateTime
  status            InvoiceResolutionStatus @default(ACTIVE)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  sales             Sale[]

  @@map("invoice_resolutions")
}

model BillingConfig {
  id                        Int      @id @default(autoincrement())
  companyId                 Int      @unique
  company                   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoicePrefixDefault      String   @default("FAC")
  invoiceFooterText           String?
  includeTaxInPrice         Boolean  @default(false)
  autoGenerateInvoiceNumber Boolean  @default(true)
  allowInvoiceWithoutResolution Boolean @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("billing_configs")
}

model User {
  id              Int                @id @default(autoincrement())
  name            String
  email           String           @unique
  password        String
  active          Boolean          @default(true)
  roleId          Int
  role            Role             @relation(fields: [roleId], references: [id])
  companyId       Int?
  branchId        Int?
  company         Company?         @relation(fields: [companyId], references: [id])
  branch          Branch?          @relation(fields: [branchId], references: [id])
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  sales           Sale[]
  inventoryMovements InventoryMovement[]
  cashRegisters   CashRegister[]
  auditLogs       AuditLog[]

  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]
}

model Provider {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  contact     String?
  phone       String?
  email       String?
  address     String?
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  products    Product[]
  purchases   Purchase[]
}

model Product {
  id            Int                  @id @default(autoincrement())
  code          String               @unique
  barcode       String?
  name          String
  description   String?
  categoryId    Int
  category      Category             @relation(fields: [categoryId], references: [id])
  providerId    Int
  provider      Provider             @relation(fields: [providerId], references: [id])
  companyId     Int?
  taxId         Int?
  company       Company?             @relation(fields: [companyId], references: [id])
  tax           Tax?                 @relation(fields: [taxId], references: [id])
  purchasePrice Float
  salePrice     Float
  stock         Int                  @default(0)
  minStock      Int                  @default(0)
  active        Boolean              @default(true)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  purchaseDetails PurchaseDetail[]
  saleDetails   SaleDetail[]
  inventoryMovements InventoryMovement[]
  returnDetails ReturnDetail[]
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  docType   String   @default("DNI")
  docNumber String?
  phone     String?
  email     String?
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sales     Sale[]
}

model Purchase {
  id           Int              @id @default(autoincrement())
  series       String?
  number       Int?
  providerId   Int
  provider     Provider         @relation(fields: [providerId], references: [id])
  userId       Int?
  companyId    Int?
  branchId     Int?
  taxTotal     Float            @default(0)
  company      Company?         @relation(fields: [companyId], references: [id])
  branch       Branch?          @relation(fields: [branchId], references: [id])
  subtotal     Float
  tax          Float            @default(0)
  total        Float
  status       PurchaseStatus   @default(COMPLETADA)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  details      PurchaseDetail[]
}

model PurchaseDetail {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitCost   Float
  subtotal   Float
}

model Sale {
  id            Int           @id @default(autoincrement())
  series        String?
  number        Int?
  clientId      Int           @default(1)
  client        Client        @relation(fields: [clientId], references: [id])
  userId        Int
  user          User          @relation(fields: [userId], references: [id])
  companyId     Int?
  branchId      Int?
  taxTotal      Float         @default(0)
  invoiceNumber String?
  invoicePrefix  String?
  invoiceResolutionId Int?
  company       Company?            @relation(fields: [companyId], references: [id])
  branch        Branch?             @relation(fields: [branchId], references: [id])
  invoiceResolution InvoiceResolution? @relation(fields: [invoiceResolutionId], references: [id])
  subtotal      Float
  discount      Float         @default(0)
  discountUser  Int?
  tax           Float         @default(0)
  total         Float
  paymentMethod PaymentMethod @default(EFECTIVO)
  status        SaleStatus    @default(COMPLETADA)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  details       SaleDetail[]
  returns       Return[]
}

model SaleDetail {
  id        Int     @id @default(autoincrement())
  saleId    Int
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
  discount  Float   @default(0)
  taxId     Int?
  taxRate   Float   @default(0)
  taxAmount Float   @default(0)
  subtotal  Float
  totalLine Float
}

model InventoryMovement {
  id        Int          @id @default(autoincrement())
  productId Int
  product   Product      @relation(fields: [productId], references: [id])
  userId    Int?
  user      User?        @relation(fields: [userId], references: [id])
  companyId Int?
  branchId  Int?
  company   Company?     @relation(fields: [companyId], references: [id])
  branch    Branch?      @relation(fields: [branchId], references: [id])
  type      MovementType
  quantity  Int
  stockBefore Int
  stockAfter  Int
  reference  String?
  referenceId Int?
  note       String?
  createdAt  DateTime     @default(now())
}

model CashRegister {
  id            Int                @id @default(autoincrement())
  userId        Int
  user          User               @relation(fields: [userId], references: [id])
  companyId     Int?
  branchId        Int?
  company       Company?           @relation(fields: [companyId], references: [id])
  branch        Branch?            @relation(fields: [branchId], references: [id])
  openingDate   DateTime           @default(now())
  closingDate   DateTime?
  initialAmount Float
  totalSales    Float              @default(0)
  totalExpenses Float              @default(0)
  expectedTotal  Float?
  actualTotal   Float?
  difference    Float?
  observations  String?
  status        CashRegisterStatus @default(ABIERTA)
  movements     CashMovement[]
}

model CashMovement {
  id            Int          @id @default(autoincrement())
  cashRegisterId Int
  cashRegister  CashRegister @relation(fields: [cashRegisterId], references: [id], onDelete: Cascade)
  type          String
  amount        Float
  description   String?
  createdAt     DateTime     @default(now())
}

model Return {
  id            Int          @id @default(autoincrement())
  saleId        Int
  sale          Sale         @relation(fields: [saleId], references: [id])
  userId        Int?
  reason        String
  subtotal      Float
  tax           Float        @default(0)
  total         Float
  createdAt     DateTime     @default(now())
  details       ReturnDetail[]
}

model ReturnDetail {
  id         Int     @id @default(autoincrement())
  returnId   Int
  return_    Return  @relation(fields: [returnId], references: [id], onDelete: Cascade)
  productId  Int
  product    Product @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Float
  subtotal   Float

  @@map("return_details")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  Int?
  detail    String?
  createdAt DateTime @default(now())
}